#!/usr/bin/env python3
import runpy
import sys
from pathlib import Path

# Ensure repo root is on sys.path so we can import beautiful_aha_epics when
# running from ./bin/bae regardless of CWD.
ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

runpy.run_module("beautiful_aha_epics.cli", run_name="__main__")
