#!/usr/bin/env python3
import sys
from pathlib import Path
import runpy

# Ensure repo root on path
ROOT = Path(__file__).resolve().parent
sys.path.insert(0, str(ROOT))

# Usage:
# - beauty                -> runs 'check' with config defaults
# - beauty --help         -> help for 'check'
# - beauty list-features  -> other subcommands work unchanged
args = sys.argv[1:]
if not args or args[0].startswith("-"):
    sys.argv = [sys.argv[0], "check", *args]
runpy.run_module("beautiful_aha_epics.cli", run_name="__main__")